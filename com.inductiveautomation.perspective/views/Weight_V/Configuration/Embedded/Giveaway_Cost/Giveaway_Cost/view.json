{
  "custom": {
    "Settings": {
      "mode": true
    },
    "Site": {
      "TestSite": 6
    },
    "Timestamps": {},
    "sku_cost": []
  },
  "params": {},
  "propConfig": {
    "custom.Settings": {
      "persistent": true
    },
    "custom.Site": {
      "persistent": true
    },
    "custom.Site.CurrentSite": {
      "binding": {
        "config": {
          "struct": {
            "CurrentSite": "{/root/CurrentSite.props.params.site}",
            "TestSite": "{this.custom.Site.TestSite}"
          },
          "waitOnAll": true
        },
        "transforms": [
          {
            "code": "\n\t\n\tLoggerName \u003d \u0027Emissions_EntryOverview_CurrentSite\u0027\n\t\n\ttry:\n\t    # Check if the quality is Bad_NotFound\n\t    if value[\u0027CurrentSite\u0027] is None:\n\t        \n\t        # Perform safe DB query\n\t        query \u003d \"SELECT * FROM system.dbo.sites WHERE site_id \u003d ?\"\n\t        siteId \u003d value[\u0027TestSite\u0027]  # Hardcoded for dummy site; could be dynamic\n\t        results \u003d system.db.runPrepQuery(query, [siteId])\n\t        \n\t        if results and len(results) \u003e 0:\n\t            # Convert dataset row to dictionary\n\t            row \u003d results[0]\n\t            siteInfo \u003d {\n\t                \"country\": row[\"country\"],\n\t                \"is_active\": row[\"is_active\"],\n\t                \"city\": row[\"city\"],\n\t                \"address1\": row[\"address1\"],\n\t                \"timezone\": row[\"timezone\"],\n\t                \"latitude\": row[\"latitude\"],\n\t                \"it_code\": row[\"it_code\"],\n\t                \"zip_code\": row[\"zip_code\"],\n\t                \"site_name\": row[\"site_name\"],\n\t                \"it_name\": row[\"it_name\"],\n\t                \"site_id\": row[\"site_id\"],\n\t                \"region\": row[\"region\"],\n\t                \"state_code\": row[\"state_code\"],\n\t                \"longitude\": row[\"longitude\"]\n\t            }\n\t            return siteInfo\n\t        else:\n\t            return {}\n\t    \n\t    else:\n\t        return value[\u0027CurrentSite\u0027]\n\t\n\t\n\texcept Exception as e:\n\t    CORE_P.Utils.logger(name\u003dLoggerName, level\u003d\u0027Error\u0027, text\u003d\"Error in transform: {{}}\".format(e))\n\t    return {}",
            "type": "script"
          }
        ],
        "type": "expr-struct"
      }
    },
    "custom.Timestamps": {
      "persistent": true
    },
    "custom.Timestamps.offset": {
      "binding": {
        "config": {
          "expression": "replace({this.custom.Site.CurrentSite.timezone},\" \",\"\")"
        },
        "transforms": [
          {
            "code": "\tfrom java.util import TimeZone, Date\n\t\n\t# Get your site timezone\n\ttz \u003d TimeZone.getTimeZone(value)\n\t\n\t# Get offset in milliseconds for current time\n\toffset_ms \u003d tz.getOffset(Date().getTime())\n\t\n\t# Convert to hours\n\toffset_hours \u003d offset_ms / (1000 * 60 * 60)\n\t\n\treturn offset_hours",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    },
    "custom.sku_cost": {
      "binding": {
        "config": {
          "enableValueCache": false,
          "parameters": {
            "mode": "{view.custom.Settings.mode}",
            "site_id": "{view.custom.Site.CurrentSite.site_id}"
          },
          "queryPath": "Weight_Q/Giveaway/GetCostForSKU",
          "returnFormat": "json"
        },
        "type": "query"
      },
      "persistent": true
    }
  },
