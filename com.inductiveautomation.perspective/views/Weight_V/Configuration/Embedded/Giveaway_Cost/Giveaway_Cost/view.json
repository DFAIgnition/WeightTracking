              "config": {
                "path": "view.custom.sku_cost"
              },
              "transforms": [
                {
                  "code": "\n    import system\n\n    offset \u003d self.view.custom.Timestamps.offset or 0\n\n    rows \u003d []\n\n    for row in value:\n\n        new_row \u003d dict(row)\n\n        start_dt \u003d new_row.get(\"effective_start_dt\")\n        end_dt   \u003d new_row.get(\"effective_end_dt\")\n\n        # 🔥 Convert timestamps\n        if start_dt is not None:\n            dt \u003d system.date.fromMillis(start_dt)\n            dt \u003d system.date.addHours(dt, offset)\n            new_row[\"effective_start_dt\"] \u003d dt\n\n        if end_dt is not None:\n            dt \u003d system.date.fromMillis(end_dt)\n            dt \u003d system.date.addHours(dt, offset)\n            new_row[\"effective_end_dt\"] \u003d dt\n\n        # 🔥 Handle aggregated IDs (from SQL)\n        ids_str \u003d new_row.get(\"all_sku_cost_ids\")\n\n        if ids_str:\n            id_list \u003d [int(x) for x in str(ids_str).split(\",\") if x]\n        else:\n            # fallback (single row case)\n            id_list \u003d [new_row.get(\"sku_cost_id\")]\n\n        new_row[\"all_sku_cost_ids\"] \u003d id_list\n        new_row[\"all_sku_cost_ids_str\"] \u003d \",\".join([str(x) for x in id_list])\n\n        # 🔥 Detect ALL vs single\n        new_row[\"is_all\"] \u003d len(id_list) \u003e 1\n\n        # Optional UI helper\n        if new_row[\"is_all\"]:\n            new_row[\"sku_display\"] \u003d \"ALL\"\n        else:\n            new_row[\"sku_display\"] \u003d str(new_row.get(\"sku_code\"))\n\n        new_row[\"edit\"] \u003d 1\n\n        rows.append(new_row)\n\n    return rows",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
