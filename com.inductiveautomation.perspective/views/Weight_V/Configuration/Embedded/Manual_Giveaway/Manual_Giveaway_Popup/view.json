                  "code": "\t\n\tif len(value)\u003e0:\n\t\tself.props.columns[3].header.title \u003d str(value[0][\u0027unit_description\u0027]) + \u0027 Lost\u0027\n\t\n\tfor row in value:\n\t\n\t\trow[\u0027display_date\u0027] \u003d row[\u0027shift_date\u0027][:4] + \"-\" + row[\u0027shift_date\u0027][4:6] + \"-\" + row[\u0027shift_date\u0027][6:]\n\t\tif (not row[\u0027loss_grams\u0027]):\n\t\t\trow[\u0027converted_loss\u0027] \u003d row[\u0027loss_grams\u0027]\n\t\t\t\n\t\telif (row[\u0027unit_conversion\u0027]):\n\t\t\trow[\u0027converted_loss\u0027]\t\u003d round(row[\u0027loss_grams\u0027]/(row[\u0027unit_conversion\u0027]*1.0),2)\n\t\telse:\n\t\t\trow[\u0027converted_loss\u0027]\t\u003d row[\u0027loss_grams\u0027]\n\t\t\n\t\t\t\n\treturn value",
                  "type": "script"
                }
