        "scripts": {
          "customMethods": [],
          "extensionFunctions": null,
          "messageHandlers": [
            {
              "messageType": "update_field",
              "pageScope": true,
              "script": "\t#CORE_P.Utils.warningPopup(\u0027here\u0027 + str())\n\tif (\u0027table\u0027 in payload and payload[\u0027table\u0027] \u003d\u003d \u0027GiveawayTable\u0027):\t\n\t\ttry:\n\t\t\tshift_id \u003d payload[ \u0027id2\u0027 ]\n\t\t\tmanual_loss_id  \u003d payload[ \u0027id\u0027 ]\n\t\t\t\t\t\t\n\t\t\t###########################################################################\t\n\t\t\t# Otherwise, do a normal value update\n\t\t\t###########################################################################\t\n\t\t\tif (manual_loss_id):\n\t\t\t\t\n\t\t\t\tupdated_values \u003d CORE_P.Utils.pythonify(self.view.custom.updated_values)\n\t\t\t\tupdated_values[shift_id] \u003d payload[\u0027new_value\u0027]\n\t\t\t\tself.view.custom.updated_values \u003d updated_values\n\t\t\t\tself.getSibling(\"SaveButton\").props.enabled \u003d True\n\t\t\t\t#CORE_P.Utils.warningPopup(\u0027updated_values\u0027 + str(updated_values))\n\t\t\t\t\n\t\t\telif (shift_id):\n\t\t\t\t\n\t\t\t\tnew_values \u003d CORE_P.Utils.pythonify(self.view.custom.new_values)\n\t\t\t\tnew_values[shift_id] \u003d payload[\u0027new_value\u0027]\n\t\t\t\tself.view.custom.new_values \u003d new_values\n\t\t\t\tself.getSibling(\"SaveButton\").props.enabled \u003d True\n\t\t\t\t#CORE_P.Utils.warningPopup(\u0027new_values\u0027 + str(new_values))\n#\t\t\t\t\n#\t\t\telse:\n#\t\t\t\tCORE_P.Utils.warningPopup(\u0027Nothing found?\u0027 + str(payload))\n\t\t\t\n\t\t\t\t\n\t\texcept:\n\t\t\tCORE_P.Utils.errorPopup(\u0027Error updating values:\u0027 + str(payload))\t\n\t",
              "sessionScope": false,
              "viewScope": false
            }
          ]
        },
        "type": "ia.display.table"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\t\n\ttry:\n\t\t# Save manual loss changes\n\t\tif(self.getSibling(\"GiveawayTable\").props.data)\u003d\u003d0:\n\t\t\tCORE_P.Utils.errorPopup(\u0027No shift data found!\u0027)\n\t\t\treturn\n\t\tshift_length \u003d self.getSibling(\"GiveawayTable\").props.data[0][\u0027shift_length\u0027]\n\t\tshift_start \u003d self.getSibling(\"GiveawayTable\").props.data[0][\u0027shift_start\u0027]\n\t\tunit_conversion \u003d self.getSibling(\"GiveawayTable\").props.data[0][\u0027unit_conversion\u0027]\n\t\t\n\t\tif (not unit_conversion):\n\t\t\tCORE_P.Utils.errorPopup(\u0027Error: No valid unit conversion found!\u0027)\n\t\t\treturn\n\t\t\n\t\tnew_values\t\t\u003d self.view.custom.new_values\n\t\tupdated_values\t\u003d self.view.custom.updated_values\n\t\t\n\t\t# Insert new values\n\t\tfor shift_id in new_values.keys():\n\t\t\tif (new_values[shift_id] \u003d\u003d None or new_values[shift_id] \u003d\u003d \u0027\u0027):\n\t\t\t\tcontinue\n\t\t\t\n\t\t\tline_id \u003d self.view.params.line_id\n\t\t\tshift_date, shift_number \u003d shift_id.split(\u0027_\u0027)\n\t\t\t\t\t\t\n\t\t\t# Get the start and end of the shift in UTC time, for database querying...\n\t\t\ttimezone \u003d self.view.params.site[\u0027timezone\u0027]# We need to get the site timezone for this to work...we also need a site_id\n\t\t\tsite_id \u003d self.view.params.site[\u0027site_id\u0027]\n\t\t\tutc_shift_start \u003d CORE_P.Time.LocalToUTC(str(shift_date[:4] + \"-\" + shift_date[4:6] + \"-\" + shift_date[6:]) + \u0027 00:00:00\u0027, timezone) \n\t\t\toffset_hours \u003d int(shift_start) + ((int(shift_number)-1)*int(shift_length))\n\t\t\tutc_shift_start \u003d CORE_P.Time.adjustTimestamp(utc_shift_start, offset_hours\u003doffset_hours) # Add on the right number of hours to get to the start of this shift\n\t\t\tutc_shift_end \u003d CORE_P.Time.adjustTimestamp(utc_shift_start, offset_hours\u003dshift_length) # Get the end of the shift\n\t\t\t\n\t\t\tparameters \u003d {\u0027site_id\u0027:site_id, \u0027start_dt\u0027:utc_shift_start, \u0027end_dt\u0027:utc_shift_end}\n\t\t\tcosts \u003d CORE_P.Utils.datasetToDicts(system.db.runNamedQuery(\n\t\t\t\t\t\t\t\t\tproject\u003dsystem.project.getProjectName(), \n\t\t\t\t\t\t\t\t\tpath\u003d\u0027Weight_Q/DB_Query/Get_Cost_By_Shift\u0027, \n\t\t\t\t\t\t\t\t\tparameters\u003dparameters\n\t\t\t\t\t\t\t\t))\n\t\t\tif (len(costs)\u003e0):\n\t\t\t\tcost_per_gram \u003d costs[0][\u0027cost_per_gram\u0027]\n\t\t\telse:\n\t\t\t\tcost_per_gram \u003d 0\n\t\t\t\n\t\t\tloss_grams \u003d round(float(new_values[shift_id]) * float(unit_conversion),2)\n\t\t\tloss_per_hour \u003d round(loss_grams/(float(shift_length)))\n\t\t\tcost_per_hour \u003d loss_per_hour * cost_per_gram\n\t\t\tedited_by \u003d self.session.props.auth.user.userName\n\t\t\tparameters \u003d {\n\t\t\t\t\u0027line_id\u0027:line_id,\n\t\t\t\t\u0027shift_id\u0027:shift_id,\n\t\t\t\t\u0027shift_date\u0027:shift_date,\n\t\t\t\t\u0027shift_number\u0027:shift_number,\n\t\t\t\t\u0027cost_per_hour\u0027:cost_per_hour,\n\t\t\t\t\u0027loss_grams\u0027:loss_grams,\n\t\t\t\t\u0027loss_per_hour\u0027:loss_per_hour,\n\t\t\t\t\u0027edited_by\u0027:edited_by,\n\t\t\t\t}\n\t\t\tsystem.db.runNamedQuery(\n\t\t\t\t\t\tproject\u003dsystem.project.getProjectName(), \n\t\t\t\t\t\tpath\u003d\u0027Weight_Q/DB_Insert/Insert_Manual_Loss\u0027, \n\t\t\t\t\t\tparameters\u003dparameters\n\t\t\t\t\t)\n\t\n\t\t# Update changed values\n\t\tfor shift_id in updated_values.keys():\n\t\t\t\n\t\t\tline_id \u003d self.view.params.line_id\n\t\t\tshift_date, shift_number \u003d shift_id.split(\u0027_\u0027)\n\t\t\t\t\t\t\n\t\t\t# Get the start and end of the shift in UTC time, for database querying...\n\t\t\ttimezone \u003d self.view.params.site[\u0027timezone\u0027]# We need to get the site timezone for this to work...we also need a site_id\n\t\t\tsite_id \u003d self.view.params.site[\u0027site_id\u0027]\n\t\t\tutc_shift_start \u003d CORE_P.Time.LocalToUTC(str(shift_date[:4] + \"-\" + shift_date[4:6] + \"-\" + shift_date[6:]) + \u0027 00:00:00\u0027, timezone) \n\t\t\toffset_hours \u003d int(shift_start) + ((int(shift_number)-1)*int(shift_length))\n\t\t\tutc_shift_start \u003d CORE_P.Time.adjustTimestamp(utc_shift_start, offset_hours\u003doffset_hours) # Add on the right number of hours to get to the start of this shift\n\t\t\tutc_shift_end \u003d CORE_P.Time.adjustTimestamp(utc_shift_start, offset_hours\u003dshift_length) # Get the end of the shift\n\t\t\t\n\t\t\tparameters \u003d {\u0027site_id\u0027:site_id, \u0027start_dt\u0027:utc_shift_start, \u0027end_dt\u0027:utc_shift_end}\n\t\t\tcosts \u003d CORE_P.Utils.datasetToDicts(system.db.runNamedQuery(\n\t\t\t\t\t\t\t\t\tproject\u003dsystem.project.getProjectName(), \n\t\t\t\t\t\t\t\t\tpath\u003d\u0027Weight_Q/DB_Query/Get_Cost_By_Shift\u0027, \n\t\t\t\t\t\t\t\t\tparameters\u003dparameters\n\t\t\t\t\t\t\t\t))\n\t\t\tif (len(costs)\u003e0):\n\t\t\t\tcost_per_gram \u003d costs[0][\u0027cost_per_gram\u0027]\n\t\t\telse:\n\t\t\t\tcost_per_gram \u003d 0\n\t\t\t\n\t\t\tloss_grams \u003d round(float(updated_values[shift_id] or 0) * float(unit_conversion),2)\n\t\t\tloss_per_hour \u003d round(loss_grams/(float(shift_length)))\n\t\t\tcost_per_hour \u003d loss_per_hour * cost_per_gram\n\t\t\tedited_by \u003d self.session.props.auth.user.userName\n\t\t\n\t\t\tparameters \u003d {\n\t\t\t\t\u0027line_id\u0027:line_id,\n\t\t\t\t\u0027shift_id\u0027:shift_id,\n\t\t\t\t\u0027cost_per_hour\u0027:cost_per_hour,\n\t\t\t\t\u0027loss_grams\u0027:loss_grams,\n\t\t\t\t\u0027loss_per_hour\u0027:loss_per_hour,\n\t\t\t\t\u0027edited_by\u0027:edited_by,\n\t\t\t\t}\n\t\t\tsystem.db.runNamedQuery(\n\t\t\t\t\t\tproject\u003dsystem.project.getProjectName(), \n\t\t\t\t\t\tpath\u003d\u0027Weight_Q/DB_Update/Update_Manual_Loss\u0027, \n\t\t\t\t\t\tparameters\u003dparameters\n\t\t\t\t\t)\n\t\t\t\t\t\n\t\tCORE_P.Utils.showSuccess(self, \"Saved!\") \n\t\tsystem.perspective.closePopup(\u0027\u0027)\n\t\t\n\texcept:\n\t\tCORE_P.Utils.errorPopup(\u0027Error saving manual losses!\u0027 + str(self.view.custom.new_values))"
